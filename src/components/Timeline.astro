---
/**
 * Timeline — a vertical, monospace "engineering-schematic" timeline of
 * education and experience. A central year axis with entries fanning out to
 * both sides; newest at the top. Duration bars are packed into lanes so
 * overlapping periods stay visible; one-off achievements render as diamonds.
 *
 * Labels are real HTML positioned beside their bar (a leader line connects
 * them) — add an `href` to an entry to turn its label into a link to a post.
 *
 * Edit the ENTRIES array to change content. Dates are "YYYY-MM".
 */

interface Entry {
  kind: "range" | "point";
  /** Bold headline line — org, institution, contest, project… */
  primary: string;
  /** Secondary line — role, result, degree… (optional) */
  secondary?: string;
  start?: string; // range
  end?: string; // range
  date?: string; // point
  dateLabel: string;
  detail: string;
  /** Optional link, e.g. "/posts/my-snowflake-internship" */
  href?: string;
}

// Present moment — the top of the axis and the "now" marker.
const NOW = "2026-07";

// Newest-first (matches the axis top-to-bottom order).
const ENTRIES: Entry[] = [
  {
    kind: "range",
    primary: "Google",
    secondary: "SWE Intern",
    start: "2026-06",
    end: "2026-08",
    dateLabel: "Jun – Aug 2026",
    detail: "Building evaluation for AI agents.",
  },
  {
    kind: "range",
    primary: "University of Warsaw",
    secondary: "BSc Computer Science",
    start: "2023-10",
    end: "2026-07",
    dateLabel: "2023 – 2026",
    detail: "GPA 4.48/5.00",
  },
  {
    kind: "range",
    primary: "Snowflake",
    secondary: "SWE Intern",
    start: "2025-06",
    end: "2025-09",
    dateLabel: "Jun – Sep 2025",
    detail: "Developed the Snowflake Universal Driver.",
  },
  {
    kind: "range",
    primary: "Atinea",
    secondary: "SWE",
    start: "2024-06",
    end: "2025-06",
    dateLabel: "2024 – 2025",
    detail: "Developed and optimized custom SQL query parser and preprocessor.",
  },
  {
    kind: "range",
    primary: "Instalogik",
    secondary: "Problem Setter",
    start: "2022-06",
    end: "2025-06",
    dateLabel: "2022 – 2025",
    detail: "Designed problems for a national contest.",
  },
  {
    kind: "range",
    primary: "Polish Olympiad in Informatics",
    secondary: "Finalist",
    start: "2021-09",
    end: "2023-03",
    dateLabel: "2021 – 2023",
    detail: "Prepared for 2 years, placed in the top 100.",
  },
];

// --- geometry -------------------------------------------------------------
const PPM = 10; // pixels per month
const TOP_PAD = 18;
const BOT_PAD = 12;
const BAR_W = 7;
const LANE_STEP = 15; // bar width (7) + gap (8) between parallel bars
const CENTER_GUTTER = 24; // clear space around the axis (year chips live here)
const LEADER_PAD = 12; // room between outermost lane and the rail edge
const LABEL_H = 74; // reserved height per label (collision avoidance)
const LABEL_GAP = 40; // min vertical gap between stacked labels
const TITLE_OFFSET = 11; // leader connects to the label's title line

const mi = (s: string) => {
  const [y, m] = s.split("-").map(Number);
  return y * 12 + (m - 1);
};
// Top of the axis = the latest date shown (so future end dates, e.g. an
// upcoming internship, don't overflow above the chart). The "now" line then
// sits below the top whenever something extends past today.
const topMI = Math.max(
  mi(NOW),
  ...ENTRIES.filter(e => e.kind === "range").map(e => mi(e.end!))
);
const yOf = (s: string) => TOP_PAD + (topMI - mi(s)) * PPM;
const clamp = (v: number, lo: number, hi: number) =>
  Math.max(lo, Math.min(hi, v));
const anchorTop = (e: Entry) =>
  e.kind === "range" ? yOf(e.end!) : yOf(e.date!);

const indexed = ENTRIES.map((e, idx) => ({ ...e, idx }));
const ranges = indexed.filter(e => e.kind === "range");
const points = indexed.filter(e => e.kind === "point");

// Assign sides: alternate ranges by start date (spreads overlapping bars
// across both sides), then balance the points onto the lighter side.
const side = new Map<number, "L" | "R">();
[...ranges]
  .sort((a, b) => mi(a.start!) - mi(b.start!))
  .forEach((e, i) => side.set(e.idx, i % 2 === 0 ? "L" : "R"));
let lc = ranges.filter(e => side.get(e.idx) === "L").length;
let rc = ranges.length - lc;
points.forEach(e => {
  const s = lc <= rc ? "L" : "R";
  side.set(e.idx, s);
  s === "L" ? lc++ : rc++;
});

// Lane packing per side (earliest start first, reuse freed lanes).
function packLanes(items: typeof ranges) {
  const ends: number[] = [];
  const laneOf = new Map<number, number>();
  [...items]
    .sort((a, b) => mi(a.start!) - mi(b.start!))
    .forEach(e => {
      let l = ends.findIndex(x => x <= mi(e.start!));
      if (l === -1) {
        l = ends.length;
        ends.push(0);
      }
      ends[l] = mi(e.end!);
      laneOf.set(e.idx, l);
    });
  return { laneOf, count: ends.length };
}
const L = packLanes(ranges.filter(e => side.get(e.idx) === "L"));
const R = packLanes(ranges.filter(e => side.get(e.idx) === "R"));

const axisX = LEADER_PAD + L.count * LANE_STEP + CENTER_GUTTER / 2;
const railW =
  LEADER_PAD + L.count * LANE_STEP + CENTER_GUTTER + R.count * LANE_STEP + LEADER_PAD;

// Greedy label stacking per side (top-most first).
function stackSide(key: "L" | "R") {
  const tops = new Map<number, number>();
  let prevBottom = -Infinity;
  indexed
    .filter(e => side.get(e.idx) === key)
    .sort((a, b) => anchorTop(a) - anchorTop(b))
    .forEach(e => {
      const top = Math.max(anchorTop(e), prevBottom + LABEL_GAP);
      prevBottom = top + LABEL_H;
      tops.set(e.idx, top);
    });
  return tops;
}
const labelTopById = new Map([...stackSide("L"), ...stackSide("R")]);

const rows = indexed.map(e => {
  const s = side.get(e.idx)!;
  const isRange = e.kind === "range";
  const barTop = anchorTop(e);
  const barBottom = isRange ? yOf(e.start!) : barTop;
  const lane = isRange
    ? (s === "L" ? L.laneOf.get(e.idx)! : R.laneOf.get(e.idx)!)
    : 0;
  const barX = !isRange
    ? axisX
    : s === "L"
      ? axisX - CENTER_GUTTER / 2 - BAR_W - lane * LANE_STEP
      : axisX + CENTER_GUTTER / 2 + lane * LANE_STEP;
  const labelTop = labelTopById.get(e.idx)!;
  const leaderEndY = labelTop + TITLE_OFFSET;
  const anchorY = clamp(leaderEndY, barTop, barBottom);
  const anchorX = isRange
    ? s === "L"
      ? barX
      : barX + BAR_W
    : s === "L"
      ? axisX - 5
      : axisX + 5;
  return {
    ...e,
    side: s,
    isRange,
    barTop,
    barHeight: Math.max(barBottom - barTop, BAR_W),
    barX,
    labelTop,
    leaderEndY,
    anchorY,
    anchorX,
    color: `var(--tl-c${(e.idx % 6) + 1})`,
  };
});

const minYear = Math.floor(Math.min(...ranges.map(e => mi(e.start!))) / 12);
const topYear = Math.floor(topMI / 12);
const yearTicks = [];
for (let y = topYear; y >= minYear; y--) {
  yearTicks.push({ y: yOf(`${y}-01`), label: String(y) });
}

const nowY = yOf(NOW);
const svgH = yOf(`${minYear}-01`) + BOT_PAD;
const maxBottom = Math.max(...rows.map(r => r.labelTop + LABEL_H));
const containerH = Math.max(svgH, maxBottom + BOT_PAD);

const leftRows = rows.filter(r => r.side === "L");
const rightRows = rows.filter(r => r.side === "R");
---

<figure
  class="tl not-prose font-app my-6"
  role="group"
  aria-label="Education and experience timeline"
>
  <div class="tl-chart" style={`height:${containerH}px`}>
    <div class="tl-side tl-left">
      {
        leftRows.map(r => {
          const Tag = r.href ? "a" : "div";
          return (
            <Tag
              class:list={["tl-label", { "tl-label-link": r.href }]}
              data-tl={r.idx}
              href={r.href}
              style={`top:${r.labelTop}px`}
            >
              <span class="tl-title">{r.primary}</span>
              <span class="tl-meta">
                {r.secondary ? `${r.secondary} · ${r.dateLabel}` : r.dateLabel}
              </span>
              <span class="tl-detail">{r.detail}</span>
            </Tag>
          );
        })
      }
    </div>

    <svg
      class="tl-rail"
      width={railW}
      height={containerH}
      viewBox={`0 0 ${railW} ${containerH}`}
      aria-hidden="true"
      focusable="false"
    >
      <line
        class="tl-axis"
        x1={axisX}
        y1={TOP_PAD}
        x2={axisX}
        y2={svgH - BOT_PAD}
      />

      <!-- leader lines -->
      {
        rows.map(r => (
          <polyline
            class="tl-lead"
            points={
              r.side === "L"
                ? `${r.anchorX},${r.anchorY} 6,${r.anchorY} 0,${r.leaderEndY}`
                : `${r.anchorX},${r.anchorY} ${railW - 6},${r.anchorY} ${railW},${r.leaderEndY}`
            }
          />
        ))
      }

      <!-- bars & markers -->
      {
        rows.map(r =>
          r.isRange ? (
            <rect
              class="tl-bar"
              data-tl={r.idx}
              style={`color:${r.color}`}
              x={r.barX}
              y={r.barTop}
              width={BAR_W}
              height={r.barHeight}
              rx={BAR_W / 2}
            />
          ) : (
            <rect
              class="tl-marker"
              data-tl={r.idx}
              style={`color:${r.color}`}
              x={axisX - 5}
              y={r.barTop - 5}
              width={10}
              height={10}
              transform={`rotate(45 ${axisX} ${r.barTop})`}
            />
          )
        )
      }

      <!-- year chips on the axis -->
      {
        yearTicks.map(t => (
          <>
            <rect
              class="tl-year-bg"
              x={axisX - 15}
              y={t.y - 8}
              width={30}
              height={16}
              rx={3}
            />
            <text class="tl-year" x={axisX} y={t.y} text-anchor="middle" dominant-baseline="middle">
              {t.label}
            </text>
          </>
        ))
      }

      <!-- now marker -->
      <circle class="tl-now-dot" cx={axisX} cy={nowY} r={3} />
      <text class="tl-now-label" x={axisX} y={nowY - 8} text-anchor="middle">now</text>
    </svg>

    <div class="tl-side tl-right">
      {
        rightRows.map(r => {
          const Tag = r.href ? "a" : "div";
          return (
            <Tag
              class:list={["tl-label", { "tl-label-link": r.href }]}
              data-tl={r.idx}
              href={r.href}
              style={`top:${r.labelTop}px`}
            >
              <span class="tl-title">{r.primary}</span>
              <span class="tl-meta">
                {r.secondary ? `${r.secondary} · ${r.dateLabel}` : r.dateLabel}
              </span>
              <span class="tl-detail">{r.detail}</span>
            </Tag>
          );
        })
      }
    </div>
  </div>

  <!-- Mobile: simple flowing list -->
  <ol class="tl-mobile">
    {
      rows.map(r => {
        const Tag = r.href ? "a" : "div";
        return (
          <li class="tl-m-item" style={`border-left-color:${r.color}`}>
            <Tag class:list={["tl-m-inner", { "tl-label-link": r.href }]} href={r.href}>
              <span class="tl-title">{r.primary}</span>
              <span class="tl-meta">
                {r.secondary ? `${r.secondary} · ${r.dateLabel}` : r.dateLabel}
              </span>
              <span class="tl-detail">{r.detail}</span>
            </Tag>
          </li>
        );
      })
    }
  </ol>
</figure>

<style>
  /* Monochromatic ramp of the site accent — visual variety only, no meaning.
     color-mix keeps every bar in the accent hue and adapts to light/dark. */
  .tl {
    --tl-c1: color-mix(in oklab, var(--accent), var(--foreground) 25%);
    --tl-c2: var(--accent);
    --tl-c3: color-mix(in oklab, var(--accent), var(--background) 30%);
    --tl-c4: color-mix(in oklab, var(--accent), var(--foreground) 12%);
    --tl-c5: color-mix(in oklab, var(--accent), var(--background) 15%);
    --tl-c6: color-mix(in oklab, var(--accent), var(--foreground) 38%);
  }

  .tl-chart {
    position: relative;
    display: flex;
    align-items: stretch;
  }
  .tl-side {
    position: relative;
    flex: 1 1 0;
    min-width: 0;
  }
  .tl-rail {
    flex: none;
  }

  .tl-axis {
    stroke: var(--muted-foreground);
    stroke-width: 1.5;
  }
  .tl-lead {
    fill: none;
    stroke: var(--border);
    stroke-width: 1.5;
  }
  .tl-bar {
    fill: currentColor;
    transition: filter 0.15s;
  }
  .tl-marker {
    fill: var(--background);
    stroke: currentColor;
    stroke-width: 2;
    transition: filter 0.15s;
  }
  .tl-bar[data-active="true"],
  .tl-marker[data-active="true"] {
    filter: drop-shadow(0 0 3px currentColor);
  }
  .tl-year-bg {
    fill: var(--background);
  }
  .tl-year {
    fill: var(--muted-foreground);
    font-size: 11px;
  }
  .tl-now-dot {
    fill: var(--accent);
  }
  .tl-now-label {
    fill: var(--accent);
    font-size: 10px;
    letter-spacing: 0.05em;
  }

  .tl-label {
    position: absolute;
    left: 0;
    right: 0;
    color: inherit;
    text-decoration: none;
  }
  .tl-left .tl-label {
    text-align: right;
    padding-right: 0.5rem;
  }
  .tl-right .tl-label {
    text-align: left;
    padding-left: 0.5rem;
  }
  .tl-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--foreground);
  }
  .tl-meta {
    display: block;
    margin-top: 0.1rem;
    font-size: 0.78rem;
    color: var(--muted-foreground);
  }
  .tl-detail {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--foreground);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tl-label-link {
    cursor: pointer;
  }
  .tl-label-link:hover .tl-title,
  .tl-label-link:focus-visible .tl-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* --- mobile list --- */
  .tl-mobile {
    display: none;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .tl-m-item {
    border-left: 3px solid var(--accent);
    padding-left: 0.9rem;
    margin-bottom: 1.25rem;
  }
  .tl-m-inner {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .tl-m-item .tl-detail {
    -webkit-line-clamp: 3;
  }

  @media (max-width: 640px) {
    .tl-chart {
      display: none;
    }
    .tl-mobile {
      display: block;
    }
  }
</style>

<script>
  // Highlight the bar that belongs to a hovered/focused label.
  function wireTimeline() {
    document.querySelectorAll<HTMLElement>(".tl-chart").forEach(chart => {
      // only the bars/markers carry [data-tl] AND these classes — this avoids
      // matching the labels, which also carry [data-tl].
      const shapes = chart.querySelectorAll<SVGElement>(".tl-bar, .tl-marker");
      chart.querySelectorAll<HTMLElement>(".tl-label").forEach(label => {
        const key = label.getAttribute("data-tl");
        const shape = Array.from(shapes).find(
          s => s.getAttribute("data-tl") === key
        );
        if (!shape) return;
        const on = () => shape.setAttribute("data-active", "true");
        const off = () => shape.removeAttribute("data-active");
        label.addEventListener("mouseenter", on);
        label.addEventListener("mouseleave", off);
        label.addEventListener("focusin", on);
        label.addEventListener("focusout", off);
      });
    });
  }
  document.addEventListener("astro:page-load", wireTimeline);
</script>
